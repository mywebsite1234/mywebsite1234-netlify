<!DOCTYPE html>
<html>
<head>
    <title>Neal.fun Archive</title>
    <script src="https://cdn.jsdelivr.net/npm/replaywebpage@2.4.3/ui.js"></script>
    <style>
        body, html { margin: 0; width: 100%; height: 100vh; overflow: hidden; background: #000; color: #00ff00; display: flex; align-items: center; justify-content: center; font-family: 'Courier New', monospace; }
        #status-box { text-align: center; border: 2px solid #00ff00; padding: 30px; background: #050505; box-shadow: 0 0 15px #00ff00; }
        .spinner { margin-top: 10px; font-size: 0.8em; opacity: 0.7; }
    </style>
</head>
<body>
    <div id="status-box">
        <div style="font-weight: bold; margin-bottom: 10px;">NEAL-OS V1.0 - ARCHIVE BOOT SEQUENCE</div>
        <div id="loading">LOADING CHUNKS: <span id="percent">0</span>%</div>
        <div id="log" class="spinner">Initializing local buffer...</div>
    </div>
    
    <replay-web-page 
        id="replay" 
        style="display:none" 
        view="replay" 
        replayBase="./">
        <!-- noSandbox="true" -->
    </replay-web-page>

    <script>
        async function loadArchive() {
            const totalParts = 18; 
            const buffers = []; 
            const log = document.getElementById('log');
            const percent = document.getElementById('percent');
            
            try {
                for (let i = 0; i < totalParts; i++) {
                    const partName = `neal.part${i.toString().padStart(2, '0')}.bin`;
                    log.innerText = `Fetching raw bytes for ${partName}...`;
                    
                    const res = await fetch(partName);
                    if (!res.ok) throw new Error(`Network blocked ${partName}`);
                    
                    const rawBytes = await res.arrayBuffer();
                    buffers.push(rawBytes);
                    
                    percent.innerText = Math.round(((i + 1) / totalParts) * 100);
                }
                
                log.innerText = "Stitching raw binary fragments...";
                const finalWacz = new File(buffers, "archive.wacz", { type: "application/octet-stream" });
                const url = URL.createObjectURL(finalWacz);
                
                log.innerText = "Mounting drive...";
                const viewer = document.getElementById('replay');
                viewer.setAttribute('source', url);
                viewer.style.display = 'block';
                document.getElementById('status-box').style.display = 'none';
                
            } catch (e) {
                document.getElementById('loading').innerHTML = `<span style="color:#ff4444">CRITICAL BOOT FAILURE</span>`;
                log.innerHTML = `<span style="color:#ff4444">ERROR: ${e.message}</span>`;
                console.error(e);
            }
        }

        loadArchive();
    </script>
</body>
</html>
